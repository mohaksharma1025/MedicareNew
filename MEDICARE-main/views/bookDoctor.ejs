<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Book Dr. <%= doctor.name %> | MediCare</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f3faf9; }
    .panel { border-radius: 8px; border: 1px solid #dcebea; }
    .doctor-photo { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 8px; }
    .btn-med { background: #0f766e; color: #fff; }
    .btn-med:hover { background: #115e59; color: #fff; }
  </style>
  <link rel="stylesheet" href="/css/medicare-ui.css">
</head>
<body>
  <main class="container py-4">
    <a class="btn btn-link px-0" href="/appointment">Back to doctors</a>
    <%- include('partials/flash') %>
    <div class="row g-4">
      <div class="col-lg-4">
        <div class="panel bg-white p-3 shadow-sm">
          <img class="doctor-photo mb-3" src="<%= doctor.image %>" alt="<%= doctor.name %>">
          <h1 class="h4">Dr. <%= doctor.name %></h1>
          <p class="mb-1"><%= doctor.degree %> | <%= doctor.specialization %></p>
          <p class="mb-1">Experience: <%= doctor.experience %> years</p>
          <p class="mb-0 fw-bold text-success">INR <%= doctor.price %> / min</p>
        </div>
      </div>
      <div class="col-lg-8">
        <form class="panel bg-white p-4 shadow-sm" method="POST" action="/book-appointment">
          <input type="hidden" name="doctorId" value="<%= doctor._id %>">
          <h2 class="h4 mb-3">Appointment Details</h2>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Patient Name</label>
              <input class="form-control" type="text" name="patientName" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Patient Email</label>
              <input class="form-control" type="email" name="patientEmail" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Date</label>
              <input class="form-control" type="date" name="appointmentDate" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Time</label>
              <input class="form-control" type="time" name="appointmentTime" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Mobile No</label>
              <input class="form-control" type="tel" name="appointmentNumber" required>
            </div>
          </div>
          <div class="alert alert-info mt-4 mb-3">
            Minimum consultation billing is 5 minutes. You will pay before the appointment is confirmed.
          </div>
          <button class="btn btn-med px-4" type="submit">Continue to Payment</button>
        </form>
      </div>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
