<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Doctor Login | MediCare</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { min-height: 100vh; background: #eef7f6; display: grid; place-items: center; }
    .login-card { width: min(420px, 92vw); border: 1px solid #d9ece9; border-radius: 8px; box-shadow: 0 14px 35px rgba(18, 59, 64, .08); }
    .brand { color: #0f766e; font-weight: 700; }
    .btn-med { background: #0f766e; color: #fff; }
    .btn-med:hover { background: #115e59; color: #fff; }
  </style>
  <link rel="stylesheet" href="/css/medicare-ui.css">
</head>
<body>
  <main class="login-card bg-white p-4">
    <h1 class="h3 brand mb-2">Doctor Login</h1>
    <p class="text-muted mb-4">Approved doctors can access their MediCare account.</p>
    <%- include('partials/flash') %>
    <form action="/doctor/login" method="POST">
      <label class="form-label">Email</label>
      <input class="form-control mb-3" type="email" name="email" required>
      <label class="form-label">Password</label>
      <input class="form-control mb-4" type="password" name="password" required>
      <button class="btn btn-med w-100" type="submit">Login</button>
    </form>
    <div class="d-flex justify-content-between mt-3">
      <a href="/doctor/register">Register</a>
      <a href="/">Home</a>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
