<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | MediCare</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { min-height: 100vh; background: #eef7f6; display: grid; place-items: center; }
    .form-card { width: min(420px, 92vw); border: 1px solid #dcebea; border-radius: 8px; }
    .btn-med { background: #0f766e; color: #fff; }
    .btn-med:hover { background: #115e59; color: #fff; }
  </style>
  <link rel="stylesheet" href="/css/medicare-ui.css">
</head>
<body>
  <main class="form-card bg-white shadow-sm p-4">
    <h1 class="h3 text-primary mb-3">Patient Login</h1>
    <%- include('partials/flash') %>
    <form action="/login" method="POST">
      <label class="form-label">Email</label>
      <input class="form-control mb-3" type="email" name="email" required>
      <label class="form-label">Password</label>
      <input class="form-control mb-4" type="password" name="password" required>
      <button type="submit" class="btn btn-med w-100">Login</button>
    </form>
    <div class="d-flex justify-content-between mt-3">
      <a href="/signup">Patient Sign Up</a>
      <a href="/doctor/login">Doctor Login</a>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
