<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MediCare | Book Verified Doctors</title>
  <link rel="stylesheet" href="/css/medicare-ui.css">
  <style>
    body.home-body {
      overflow-x: hidden;
      background: #F6F8FB !important;
    }

    .home-main {
      overflow: hidden;
    }

    .home-container {
      width: min(1140px, calc(100% - 40px));
      margin: 0 auto;
    }

    .compact-hero {
      min-height: calc(100vh - 85px);
      display: grid;
      align-items: center;
      padding: 58px 0;
      background: linear-gradient(180deg, #FFFFFF 0%, #F6F8FB 100%);
      border-bottom: 1px solid #E3E9F2;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(360px, 500px);
      gap: 56px;
      align-items: center;
    }

    .hero-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: #0B5F59;
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .hero-kicker::before {
      content: "";
      width: 28px;
      height: 2px;
      border-radius: 999px;
      background: #0F766E;
    }

    .hero-title {
      max-width: 700px;
      margin: 16px 0 20px;
      color: #08111F;
      font-size: 68px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: 0;
    }

    .hero-copy {
      max-width: 610px;
      margin: 0 0 28px;
      color: #48566A;
      font-size: 18px;
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 28px;
    }

    .home-btn {
      min-width: 146px;
      border-radius: 8px !important;
    }

    .hero-points {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      max-width: 640px;
    }

    .hero-point {
      min-height: 76px;
      padding: 14px;
      border: 1px solid #E3E9F2;
      border-radius: 8px;
      background: #FFFFFF;
      box-shadow: 0 12px 26px rgba(15, 23, 42, .05);
    }

    .hero-point strong {
      display: block;
      color: #08111F;
      font-size: 15px;
      margin-bottom: 4px;
    }

    .hero-point span {
      color: #64748B;
      font-size: 13px;
      font-weight: 760;
    }

    .hero-photo-wrap {
      position: relative;
      min-height: 410px;
    }

    .hero-photo {
      aspect-ratio: 16 / 10;
      overflow: hidden;
      border-radius: 8px;
      background: #DDE7EE;
      box-shadow: 0 28px 70px rgba(15, 23, 42, .16);
    }

    .hero-photo img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }

    .photo-panel {
      position: absolute;
      left: -36px;
      bottom: 28px;
      width: min(320px, calc(100% - 24px));
      padding: 18px;
      border: 1px solid #DDE6EF;
      border-radius: 8px;
      background: rgba(255, 255, 255, .96);
      box-shadow: 0 22px 52px rgba(15, 23, 42, .15);
    }

    .photo-panel strong {
      display: block;
      color: #08111F;
      font-size: 18px;
      margin-bottom: 6px;
    }

    .photo-panel span {
      color: #64748B;
      font-weight: 760;
    }

    .benefit-section {
      padding: 46px 0 62px;
    }

    .benefit-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .benefit-card {
      min-height: 158px;
      padding: 22px;
      border: 1px solid #E3E9F2;
      border-radius: 8px;
      background: #FFFFFF;
      box-shadow: 0 14px 32px rgba(15, 23, 42, .06);
    }

    .benefit-number {
      display: inline-grid;
      place-items: center;
      width: 34px;
      height: 34px;
      margin-bottom: 18px;
      border-radius: 8px;
      background: #E6F7F4;
      color: #0B5F59;
      font-weight: 900;
    }

    .benefit-card h2 {
      margin: 0 0 8px;
      color: #08111F;
      font-size: 21px;
      letter-spacing: 0;
    }

    .benefit-card p {
      margin: 0;
      color: #64748B;
    }

    #chatbot {
      position: fixed;
      right: 22px;
      bottom: 22px;
      width: 340px;
      z-index: 60;
      border-radius: 8px;
      box-shadow: 0 24px 54px rgba(15, 23, 42, .20);
    }

    #chatbot-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      background: #0F172A;
      color: #FFFFFF;
      padding: 14px 16px;
      border-radius: 8px 8px 0 0;
      font-weight: 900;
      cursor: pointer;
    }

    #chatbot-header span {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #2DD4BF;
    }

    #chatbot-body {
      display: none;
      height: 388px;
      padding: 12px;
      background: #FFFFFF;
      border: 1px solid #E3E9F2;
      border-top: 0;
      border-radius: 0 0 8px 8px;
    }

    #chat-messages {
      height: 304px;
      overflow-y: auto;
      padding-right: 4px;
    }

    .chat-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 8px;
      margin-top: 10px;
    }

    .chat-row input,
    .chat-row button {
      min-height: 42px;
      border-radius: 8px !important;
    }

    .chat-message {
      display: flex;
      margin: 8px 0;
    }

    .chat-message.user {
      justify-content: flex-end;
    }

    .chat-bubble {
      max-width: 82%;
      padding: 9px 11px;
      border-radius: 8px;
      background: #EEF3F7;
      color: #0F172A;
      line-height: 1.45;
      font-weight: 650;
    }

    .chat-message.user .chat-bubble {
      background: #0F766E;
      color: #FFFFFF;
    }

    @media (max-width: 980px) {
      .compact-hero {
        min-height: auto;
      }

      .hero-grid {
        grid-template-columns: 1fr;
      }

      .hero-title {
        font-size: 54px;
      }

      .hero-photo-wrap {
        max-width: 560px;
        min-height: auto;
      }
    }

    @media (max-width: 680px) {
      .home-container {
        width: min(100% - 28px, 1140px);
      }

      .compact-hero {
        padding: 38px 0;
      }

      .hero-title {
        font-size: 40px;
        line-height: 1.06;
      }

      .hero-copy {
        font-size: 16px;
      }

      .hero-actions {
        align-items: stretch;
        flex-direction: column;
      }

      .home-btn {
        width: 100%;
      }

      .hero-points,
      .benefit-grid {
        grid-template-columns: 1fr;
      }

      .hero-photo {
        aspect-ratio: 16 / 11;
      }

      .photo-panel {
        position: static;
        width: 100%;
        margin-top: 12px;
      }

      #chatbot {
        left: 14px;
        right: 14px;
        width: auto;
      }
    }
  </style>
</head>
<body class="home-body">
  <%- include('partials/navbar', { activePage: 'home', user }) %>

  <main class="home-main">
    <section class="compact-hero">
      <div class="home-container hero-grid">
        <div>
          <div class="hero-kicker">MediCare</div>
          <h1 class="hero-title">Book verified doctors online.</h1>
          <p class="hero-copy">Find trusted doctors, pay securely, and access prescriptions from one simple healthcare platform.</p>
          <div class="hero-actions">
            <a class="btn btn-primary home-btn" href="/appointment">Find Doctors</a>
            <% if (user) { %>
              <a class="btn btn-soft home-btn" href="/my-bookings">My Bookings</a>
            <% } else { %>
              <a class="btn btn-soft home-btn" href="/login">Login</a>
            <% } %>
          </div>
          <div class="hero-points" aria-label="MediCare highlights">
            <div class="hero-point"><strong>Verified doctors</strong><span>Admin-approved profiles</span></div>
            <div class="hero-point"><strong>Secure payment</strong><span>Protected booking flow</span></div>
            <div class="hero-point"><strong>Digital records</strong><span>Receipts and prescriptions</span></div>
          </div>
        </div>

        <div class="hero-photo-wrap">
          <div class="hero-photo">
            <img src="/uploads/home-doctor-male.jpg" alt="Doctor in a white coat">
          </div>
          <div class="photo-panel">
            <strong>Book care in minutes</strong>
            <span>Choose a doctor, confirm payment, and keep your records organized.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="benefit-section">
      <div class="home-container benefit-grid">
        <article class="benefit-card">
          <span class="benefit-number">1</span>
          <h2>Find doctors</h2>
          <p>Browse approved doctors by specialty and consultation fee.</p>
        </article>
        <article class="benefit-card">
          <span class="benefit-number">2</span>
          <h2>Book securely</h2>
          <p>Confirm appointments only after successful online payment.</p>
        </article>
        <article class="benefit-card">
          <span class="benefit-number">3</span>
          <h2>View records</h2>
          <p>Access meeting links, receipts, and prescriptions anytime.</p>
        </article>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <div id="chatbot">
    <div id="chatbot-header">Chat with MediCare Assistant <span></span></div>
    <div id="chatbot-body">
      <div id="chat-messages"></div>
      <div class="chat-row">
        <input type="text" id="chat-input" placeholder="Type a message">
        <button type="button" onclick="sendMessage()">Send</button>
      </div>
    </div>
  </div>

  <script>
    const chatbotHeader = document.getElementById('chatbot-header');
    const chatbotBody = document.getElementById('chatbot-body');
    const chatMessages = document.getElementById('chat-messages');

    chatbotHeader.addEventListener('click', () => {
      chatbotBody.style.display = chatbotBody.style.display === 'block' ? 'none' : 'block';
    });

    function appendMessage(text, role) {
      const row = document.createElement('div');
      row.className = `chat-message ${role}`;

      const bubble = document.createElement('span');
      bubble.className = 'chat-bubble';
      bubble.textContent = text;

      row.appendChild(bubble);
      chatMessages.appendChild(row);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    async function sendMessage() {
      const input = document.getElementById('chat-input');
      const message = input.value.trim();
      if (!message) return;

      appendMessage(message, 'user');
      input.value = '';

      try {
        const response = await fetch('/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message })
        });
        const data = await response.json();
        appendMessage(data.reply || 'I could not find an answer right now.', 'bot');
      } catch (error) {
        appendMessage('The assistant is unavailable right now. Please try again later.', 'bot');
      }
    }
  </script>
</body>
</html>
