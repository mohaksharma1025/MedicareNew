<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment | MediCare</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f3faf9; }
    .summary { border: 1px solid #dcebea; border-radius: 8px; }
    .btn-med { background: #0f766e; color: #fff; }
    .btn-med:hover { background: #115e59; color: #fff; }
  </style>
  <link rel="stylesheet" href="/css/medicare-ui.css">
</head>
<body>
  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <section class="summary bg-white shadow-sm p-4">
          <h1 class="h3 mb-3">Complete Payment</h1>
          <div id="paymentAlert"></div>
          <dl class="row mb-4">
            <dt class="col-sm-4">Doctor</dt>
            <dd class="col-sm-8">Dr. <%= doctor.name %> (<%= doctor.specialization %>)</dd>
            <dt class="col-sm-4">Patient</dt>
            <dd class="col-sm-8"><%= appointment.patientName %></dd>
            <dt class="col-sm-4">Date / Time</dt>
            <dd class="col-sm-8"><%= appointment.date %> at <%= appointment.time %></dd>
            <dt class="col-sm-4">Consultation Fee</dt>
            <dd class="col-sm-8 fw-bold">INR <%= amount %></dd>
          </dl>
          <button id="payBtn" class="btn btn-med btn-lg w-100" type="button">Pay with Razorpay</button>
          <a class="btn btn-link w-100 mt-2" href="/appointment">Cancel</a>
        </section>
      </div>
    </div>
  </main>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    const alertBox = document.getElementById('paymentAlert');
    const payBtn = document.getElementById('payBtn');

    function showAlert(type, message) {
      alertBox.innerHTML = `<div class="alert alert-${type}" role="alert">${message}</div>`;
    }

    payBtn.addEventListener('click', function () {
      const options = {
        key: '<%= razorpayKeyId %>',
        amount: '<%= order.amount %>',
        currency: 'INR',
        name: 'MediCare',
        description: 'Doctor consultation payment',
        order_id: '<%= order.id %>',
        prefill: {
          name: '<%= appointment.patientName %>',
          email: '<%= appointment.patientEmail %>',
          contact: '<%= appointment.patientPhone || "" %>'
        },
        theme: { color: '#0f766e' },
        handler: async function (response) {
          payBtn.disabled = true;
          showAlert('info', 'Verifying payment...');

          const result = await fetch('/payments/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              appointmentId: '<%= appointment._id %>',
              razorpay_order_id: response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature: response.razorpay_signature
            })
          });

          const data = await result.json();
          if (data.success) {
            window.location.href = data.redirectUrl;
          } else {
            payBtn.disabled = false;
            showAlert('danger', data.message || 'Payment verification failed.');
          }
        }
      };

      const checkout = new Razorpay(options);
      checkout.on('payment.failed', async function () {
        await fetch('/payments/failed', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ appointmentId: '<%= appointment._id %>' })
        });
        showAlert('danger', 'Payment failed. Please try again.');
      });
      checkout.open();
    });
  </script>
</body>
</html>
