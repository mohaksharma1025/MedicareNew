<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reject Doctor | MediCare</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/medicare-ui.css">
  <link rel="stylesheet" href="/css/admin-ui.css">
</head>
<body class="admin-body">
  <div class="app-shell admin-shell">
    <%- include('../partials/sidebar', { activePage: 'pending', sidebarTitle: 'MediCare Admin', sidebarRole: 'admin' }) %>

    <main class="admin-main">
      <div class="admin-topbar">
        <div>
          <h1 class="admin-title">Reject Doctor</h1>
          <p class="admin-subtitle">This reason is saved in doctor history and emailed to the doctor.</p>
        </div>
        <a class="btn btn-soft" href="/admin/doctors/pending">Cancel</a>
      </div>

      <%- include('../partials/flash') %>

      <section class="admin-panel admin-form-panel">
        <div class="admin-doctor-summary mb-4">
          <img class="admin-photo" src="<%= doctor.image %>" alt="<%= doctor.name %>">
          <div>
            <h2>Dr. <%= doctor.name %></h2>
            <p class="admin-small"><%= doctor.email %> | <%= doctor.specialization %></p>
          </div>
        </div>
        <form method="POST" action="/admin/reject/<%= doctor._id %>">
          <label class="form-label">Rejection Reason</label>
          <textarea class="form-control mb-3" name="rejectionReason" rows="5" required></textarea>
          <div class="admin-actions">
            <button class="btn btn-danger" type="submit">Reject Doctor</button>
            <a class="btn btn-soft" href="/admin/doctors/pending">Cancel</a>
          </div>
        </form>
      </section>
    </main>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
