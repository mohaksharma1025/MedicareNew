<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Appointment Confirmed | MediCare</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { min-height: 100vh; background: #eef7f6; display: grid; place-items: center; }
    .box { width: min(620px, 92vw); border: 1px solid #dcebea; border-radius: 8px; }
  </style>
  <link rel="stylesheet" href="/css/medicare-ui.css">
</head>
<body>
  <main class="box bg-white p-4 shadow-sm text-center">
    <%- include('partials/flash') %>
    <h1 class="h3 text-success">Appointment Confirmed</h1>
    <p class="text-muted">Payment is verified and confirmation emails have been sent.</p>
    <% if (appointment) { %>
      <div class="text-start bg-light p-3 rounded mb-3">
        <p class="mb-1"><strong>Doctor:</strong> Dr. <%= appointment.doctorName %></p>
        <p class="mb-1"><strong>Date:</strong> <%= formatDateOnly(appointment.date) %></p>
        <p class="mb-1"><strong>Time:</strong> <%= appointment.time %></p>
        <p class="mb-1"><strong>Meeting Link:</strong> <a href="<%= appointment.meetingLink %>" target="_blank"><%= appointment.meetingLink || 'N/A' %></a></p>
        <p class="mb-1"><strong>Receipt:</strong> <%= appointment.receiptNumber || 'N/A' %></p>
        <p class="mb-0"><strong>Payment ID:</strong> <%= appointment.paymentId %></p>
      </div>
    <% } %>
    <p>Please join the meeting at the scheduled time.</p>
    <% if (appointment) { %>
      <a href="/payments/receipt/<%= appointment._id %>" class="btn btn-success">Download Receipt</a>
    <% } %>
    <a href="/" class="btn btn-primary">Go Back to Home Page</a>
  </main>
</body>
</html>
