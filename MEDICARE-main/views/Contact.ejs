<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact | MediCare</title>
  <link rel="stylesheet" href="/css/medicare-ui.css">
  <style>
    .page-shell { max-width: 1080px; margin: 34px auto; padding: 0 24px; }
    .top-row { display: flex; justify-content: space-between; align-items: center; gap: 14px; margin-bottom: 22px; }
    .contact-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 18px; align-items: start; }
    .contact-panel { padding: 28px; }
    .contact-panel h1 { font-size: clamp(2rem, 4vw, 3.4rem); margin-bottom: 10px; }
    .contact-panel p { color: var(--mc-muted); }
    form { display: grid; gap: 14px; margin-top: 20px; }
    .info-list { display: grid; gap: 14px; }
    .info-item { padding: 16px; border: 1px solid var(--mc-border); border-radius: 8px; background: #fff; }
    .info-item span { display: block; color: var(--mc-muted); font-size: 13px; font-weight: 800; margin-bottom: 6px; text-transform: uppercase; }
    @media (max-width: 860px) { .contact-grid { grid-template-columns: 1fr; } .top-row { flex-direction: column; align-items: flex-start; } }
  </style>
</head>
<body>
  <main class="page-shell">
    <div class="top-row">
      <strong class="mc-brand"><span class="brand-mark">M</span>MediCare</strong>
      <a class="btn btn-light" href="/">Home</a>
    </div>
    <section class="contact-grid">
      <div class="panel contact-panel">
        <div class="eyebrow">Contact</div>
        <h1>Send us a message.</h1>
        <p>Questions about appointments, doctor verification, payments, or prescriptions? We will get back to you.</p>
        <form action="/contact" method="POST">
          <input type="text" name="name" placeholder="Full name" required>
          <input type="email" name="email" placeholder="Email address" required>
          <input type="text" name="subject" placeholder="Subject" required>
          <textarea name="message" placeholder="Message" required></textarea>
          <button type="submit">Submit Message</button>
        </form>
      </div>
      <aside class="panel contact-panel">
        <h2>Contact Information</h2>
        <div class="info-list">
          <div class="info-item"><span>Email</span><a href="mailto:vermapritka65@gmail.com">vermapritka65@gmail.com</a></div>
          <div class="info-item"><span>Email</span><a href="mailto:mohaksharma1025@gmail.com">mohaksharma1025@gmail.com</a></div>
          <div class="info-item"><span>Email</span><a href="mailto:madhavsharma14995@gmail.com">madhavsharma14995@gmail.com</a></div>
        </div>
      </aside>
    </section>
  </main>
</body>
</html>
