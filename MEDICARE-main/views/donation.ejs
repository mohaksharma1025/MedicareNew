<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Donate | MediCare</title>
  <link rel="stylesheet" href="/css/medicare-ui.css">
  <style>
    .page-shell { min-height: 100vh; display: grid; place-items: center; padding: 28px; }
    .donation-panel { width: min(680px, 100%); padding: 38px; text-align: center; }
    .donation-panel h1 { font-size: clamp(2rem, 4vw, 3.4rem); margin-bottom: 12px; }
    .donation-panel p { color: var(--mc-muted); font-size: 18px; }
    .upi { margin: 24px 0; padding: 18px; border: 1px dashed var(--mc-primary); border-radius: 8px; background: #ecfdf8; color: var(--mc-primary-strong); font-size: 22px; font-weight: 900; }
  </style>
</head>
<body>
  <main class="page-shell">
    <section class="panel donation-panel">
      <div class="eyebrow">Donate</div>
      <h1>Support accessible care.</h1>
      <p>Your contribution helps MediCare keep healthcare access simple and reachable.</p>
      <div class="upi">pritkaverma@okicici</div>
      <a class="btn" href="/">Back to Home</a>
    </section>
  </main>
</body>
</html>
